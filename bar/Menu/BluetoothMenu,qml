import "../.."
import "../../services"
import QtQuick
import QtQuick.Controls 2.15
import QtQuick.Layouts
import Quickshell

PopupWindow {
    id: popup

    property var anchorItem: null

    anchor: Quickshell.AnchorTop | Quickshell.AnchorRight
    margins.top: Theme.barHeight + 5
    margins.right: Theme.barMarginRight

    Rectangle {
        width: 300
        implicitHeight: 400 // Set a fixed height for testing
        color: Theme.pillColor
        radius: 12
        border.color: Theme.accentColor
        border.width: 1

        ColumnLayout {
            id: layout

            anchors.fill: parent
            anchors.margins: 12
            spacing: 10

            RowLayout {
                Layout.fillWidth: true

                Text {
                    text: "Bluetooth"
                    color: "white"
                    font.bold: true
                }

                Item {
                    Layout.fillWidth: true
                }
                // Power Toggle

                Text {
                    text: BluetoothService.powered ? "󰂯" : "󰂲"
                    font.family: Theme.iconFont
                    color: BluetoothService.powered ? Theme.accentColor : "gray"

                    MouseArea {
                        anchors.fill: parent
                        onClicked: BluetoothService.togglePower()
                    }

                }

            }

            ListView {
                Layout.fillWidth: true
                Layout.preferredHeight: Math.min(contentHeight, 300)
                model: BluetoothService.devices
                clip: true

                delegate: Rectangle {
                    width: 276
                    height: 40
                    color: "transparent"

                    RowLayout {
                        anchors.fill: parent

                        Text {
                            text: name
                            color: "white"
                            elide: Text.ElideRight
                            Layout.fillWidth: true
                        }

                        Text {
                            text: "󱘖" // Connect icon
                            font.family: Theme.iconFont
                            color: Theme.accentColor

                            MouseArea {
                                anchors.fill: parent
                                onClicked: BluetoothService.action("connect", address)
                            }

                        }

                        Text {
                            text: "󰆴" // Unpair icon
                            font.family: Theme.iconFont
                            color: "#ee99a0"

                            MouseArea {
                                anchors.fill: parent
                                onClicked: BluetoothService.action("remove", address)
                            }

                        }

                    }

                }

            }

        }

    }

}
